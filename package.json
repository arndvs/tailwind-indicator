{
  "name": "tailwind-indicator",
  "version": "0.2.0",
  "description": "Tiny screen-size indicator for Tailwind CSS — shows current breakpoint, dimensions, orientation, and pixel ratio",
  "author": "arndvs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/arndvs/tailwind-indicator.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./global": {
      "types": "./global.d.ts"
    }
  },
  "files": [
    "dist",
    "global.d.ts"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "tailwind",
    "tailwindcss",
    "indicator",
    "breakpoint",
    "debug",
    "responsive",
    "web-component",
    "custom-element"
  ],
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
